{
  "entities": {
    "user_profiles": {
      "title": "User Profile",
      "description": "Public and private user data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "email": { "type": "string", "description": "Email address of the user." },
        "photoURL": { "type": "string", "description": "Profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "chat_sessions": {
      "title": "Chat Session",
      "description": "A conversation session containing multiple messages.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "messages": {
      "title": "Message",
      "description": "Individual chat message.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "role", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user_profiles",
      "description": "User profile document."
    },
    "/chat_sessions/{sessionId}": {
      "schema": "chat_sessions",
      "description": "Chat session document."
    },
    "/chat_sessions/{sessionId}/messages/{messageId}": {
      "schema": "messages",
      "description": "Messages within a session."
    }
  }
}
